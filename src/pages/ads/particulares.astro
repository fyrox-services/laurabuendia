---
import AdsLayout from "@/layouts/AdsLayout.astro";
import HeroAds from "@/components/HeroAds.astro";
import PainCards from "@/components/PainCards.astro";
import ScenarioCards from "@/components/ScenarioCards.astro";
import WhyLauraVideo from "@/components/WhyLauraVideo.astro";
import ProcessSteps from "@/components/ProcessSteps.astro";
import { MainForm } from "@/components/preact/MainForm";
import MainCta from "@/components/MainCta.astro";
import Heading from "@/components/Heading.astro";
import Section from "@/components/Section.astro";
import CenterContent from "@/components/CenterContent.astro";
import FAQ from "@/components/FAQ.astro";
import { FAQ_ADS_PARTICULARES } from "@/data/faqs";
---

<AdsLayout
  metaTitle="Informe pericial médico para tu reclamación | Laura Buendía"
  metaDescription="Valoración del daño corporal e informes periciales médicos para reclamar la indemnización que te corresponde. Solicita un estudio de viabilidad sin compromiso."
>
  <HeroAds />
  <Section>
    <Heading>Esto es lo que suele pasar cuando reclamas tú solo</Heading>
    <PainCards />
    <div class="cta-row">
      <MainCta>contáctame aquí</MainCta>
    </div>
  </Section>
  <Section>
    <Heading>¿Te sientes identificado con alguno de estos casos?</Heading>
    <ScenarioCards />
    <div class="cta-row">
      <MainCta>contáctame aquí</MainCta>
    </div>
  </Section>
  <Section>
    <CenterContent>
      <Heading class="text-center">
        Esto marcará la diferencia
      </Heading>
      <WhyLauraVideo />
    </CenterContent>
  </Section>

  <Section>
    <CenterContent>
      <MainForm client:visible modifier="landing" />
    </CenterContent>
  </Section>
  <Section>
    <Heading class="text-center">Cómo trabajaremos</Heading>
    <ProcessSteps />
    <div class="cta-row">
      <MainCta>contáctame aquí</MainCta>
    </div>
  </Section>
  <Section>
    <CenterContent modifier="faq-section">
      <Heading>preguntas frecuentes</Heading>
      <FAQ faqs={FAQ_ADS_PARTICULARES} />
    </CenterContent>
  </Section>
</AdsLayout>

<style>
  .cta-row {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }
</style>
